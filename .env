# Application Configuration
APP_NAME=base-template
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api/v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=template_db
DB_USER=dev_user
DB_PASSWORD=dev_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=ebe9a6b23ccb0021eb69af5ad8bc0c751d2d21c2a4f154e32df9b51f5988357c
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_COOKIE_NAME=jwt-token
JWT_REFRESH_EXPIRATION_DAYS=7

# Logging Configuration
LOG_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOG_LEVEL_APP=DEBUG
LOG_FILE_NAME=logs/application.log
LOG_FILE_MAX_SIZE=10MB
LOG_FILE_MAX_HISTORY=30
LOG_FILE_TOTAL_SIZE_CAP=1GB

# Flyway Configuration
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true

# Docker Compose
DOCKER_COMPOSE_FILE=docker-compose.yml

# i18n Configuration
MESSAGES_BASENAME=i18n/messages
MESSAGES_ENCODING=UTF-8

# Swagger Configuration
SPRINGDOC_API_DOCS_PATH=/v3/api-docs
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html